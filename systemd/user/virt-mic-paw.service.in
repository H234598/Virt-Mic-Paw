[Unit]
Description=Virt-Mic-Paw virtual mixed microphone
Documentation=https://github.com/H234598/Virt-Mic-Paw
After=pipewire.service pipewire-pulse.service wireplumber.service
Wants=pipewire-pulse.service wireplumber.service

[Service]
Type=oneshot
ExecStart=@BINDIR@/virt-mic-paw start
ExecStop=@BINDIR@/virt-mic-paw stop
RemainAfterExit=yes

[Install]
WantedBy=default.target
