#!/usr/bin/env bash
set -euo pipefail

APP="virt-mic-paw"
VERSION="0.1.1"
USER_ID="${UID:-}"
if [[ -z "$USER_ID" ]]; then
  USER_ID="$(id -u)"
fi
BUS_SINK="virtmicpaw_bus"
VIRT_SOURCE="virtmicpaw"
BUS_DESC="Virt-Mic-Paw Mix-Bus"
SOURCE_DESC="Virt-Mic-Paw-Mixed-Microphone"
STATE_FALLBACK_BASE=0
if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
  STATE_BASE_DIR="$XDG_RUNTIME_DIR"
else
  STATE_FALLBACK_BASE=1
  STATE_BASE_DIR="/tmp/virt-mic-paw-$USER_ID"
fi
STATE_DIR="$STATE_BASE_DIR/virt-mic-paw"
STATE_FILE="$STATE_DIR/modules"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/virt-mic-paw"
CONFIG_FILE="$CONFIG_DIR/config.env"
LATENCY_MSEC="20"
SET_DEFAULT_SOURCE="1"
MIC_SOURCE=""
SINK=""
MONITOR_SOURCE=""

log() { printf '%s\n' "$*"; }
warn() { printf 'WARN: %s\n' "$*" >&2; }
err() { printf 'ERROR: %s\n' "$*" >&2; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || { err "Benötigter Befehl fehlt: $1"; exit 1; }; }

usage() {
  cat <<'EOF'
Virt-Mic-Paw - virtuelles Mikrofon aus Mikrofon plus Systemaudio

Usage:
  virt-mic-paw start [--mic SOURCE] [--sink SINK | --monitor SOURCE] [--latency MS] [--no-default]
  virt-mic-paw stop
  virt-mic-paw restart [Optionen wie start]
  virt-mic-paw status
  virt-mic-paw list
  virt-mic-paw config
  virt-mic-paw diag
  virt-mic-paw version
  virt-mic-paw --version
  virt-mic-paw help

Beispiele:
  virt-mic-paw start
  virt-mic-paw start --latency 50
  virt-mic-paw start --mic alsa_input.foo --sink alsa_output.bar
  virt-mic-paw list

Konfiguration:
  ~/.config/virt-mic-paw/config.env

Variablen:
  VMP_MIC_SOURCE=""
  VMP_SINK=""
  VMP_MONITOR_SOURCE=""
  VMP_LATENCY_MSEC="20"
  VMP_SET_DEFAULT_SOURCE="1"
EOF
}

show_version() {
  printf '%s %s\n' "$APP" "$VERSION"
}

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    validate_config_permissions
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
    MIC_SOURCE="${VMP_MIC_SOURCE:-$MIC_SOURCE}"
    SINK="${VMP_SINK:-$SINK}"
    MONITOR_SOURCE="${VMP_MONITOR_SOURCE:-$MONITOR_SOURCE}"
    LATENCY_MSEC="${VMP_LATENCY_MSEC:-$LATENCY_MSEC}"
    SET_DEFAULT_SOURCE="${VMP_SET_DEFAULT_SOURCE:-$SET_DEFAULT_SOURCE}"
  fi
}

validate_config_permissions() {
  validate_secure_path "$CONFIG_DIR" "Config-Verzeichnis" "directory"
  validate_secure_path "$CONFIG_FILE" "Konfiguration" "file"
}

validate_secure_path() {
  local path="$1" label="$2" expected_type="$3"
  if [[ -L "$path" ]]; then
    err "$label darf kein Symlink sein: $path"
    exit 1
  fi
  case "$expected_type" in
    directory)
      if [[ ! -d "$path" ]]; then
        err "$label ist kein Verzeichnis: $path"
        exit 1
      fi
      ;;
    file)
      if [[ ! -f "$path" ]]; then
        err "$label ist keine reguläre Datei: $path"
        exit 1
      fi
      ;;
  esac
  validate_owned_not_writable "$path" "$label"
}

validate_owned_not_writable() {
  local path="$1" label="$2"
  local path_stat owner mode group_perm other_perm
  path_stat="$(stat -c '%u %a' "$path" 2>/dev/null || true)"
  read -r owner mode <<<"$path_stat"
  if [[ ! "$owner" =~ ^[0-9]+$ || ! "$mode" =~ ^[0-7]+$ || ${#mode} -lt 3 ]]; then
    warn "Konnte Rechte nicht prüfen: $path"
    return
  fi
  if [[ "$owner" != "$USER_ID" ]]; then
    err "$label gehört nicht dem aktuellen Nutzer: $path"
    exit 1
  fi
  group_perm="${mode: -2:1}"
  other_perm="${mode: -1}"
  if (( (group_perm & 2) != 0 || (other_perm & 2) != 0 )); then
    err "$label ist gruppen- oder welt-schreibbar: $path"
    err "Korrigiere die Rechte mit: chmod go-w '$path'"
    exit 1
  fi
}

write_default_config() {
  mkdir -p "$CONFIG_DIR"
  if [[ -L "$CONFIG_DIR" ]]; then
    err "Config-Verzeichnis darf kein Symlink sein: $CONFIG_DIR"
    exit 1
  fi
  chmod 0700 "$CONFIG_DIR"
  validate_secure_path "$CONFIG_DIR" "Config-Verzeichnis" "directory"
  if [[ -e "$CONFIG_FILE" || -L "$CONFIG_FILE" ]]; then
    validate_config_permissions
    log "Konfiguration existiert bereits: $CONFIG_FILE"
    return
  fi
  cat >"$CONFIG_FILE" <<'EOF'
# Virt-Mic-Paw Konfiguration
# Leere Werte bedeuten: automatisch erkennen.

# Echtes Mikrofon. Siehe: virt-mic-paw list
VMP_MIC_SOURCE=""

# Ausgabe-Sink. Aus diesem wird automatisch .monitor gebildet.
VMP_SINK=""

# Alternativ direkt eine Monitor-Source setzen.
VMP_MONITOR_SOURCE=""

# Höhere Werte können Knacksen reduzieren, erhöhen aber die Verzögerung.
VMP_LATENCY_MSEC="20"

# 1 = virtuelles Mikrofon als Default-Eingabe setzen, 0 = nicht ändern.
VMP_SET_DEFAULT_SOURCE="1"
EOF
  chmod 0600 "$CONFIG_FILE"
  log "Konfiguration erstellt: $CONFIG_FILE"
}

ensure_state_dir() {
  if [[ "$STATE_FALLBACK_BASE" -eq 1 ]]; then
    mkdir -p "$STATE_BASE_DIR"
    if [[ -L "$STATE_BASE_DIR" ]]; then
      err "State-Basisverzeichnis darf kein Symlink sein: $STATE_BASE_DIR"
      exit 1
    fi
    chmod 0700 "$STATE_BASE_DIR"
    validate_secure_path "$STATE_BASE_DIR" "State-Basisverzeichnis" "directory"
  fi
  mkdir -p "$STATE_DIR"
  if [[ -L "$STATE_DIR" ]]; then
    err "State-Verzeichnis darf kein Symlink sein: $STATE_DIR"
    exit 1
  fi
  chmod 0700 "$STATE_DIR"
  validate_secure_path "$STATE_DIR" "State-Verzeichnis" "directory"
}

validate_state_file() {
  if [[ -L "$STATE_FILE" ]]; then
    err "State-Datei darf kein Symlink sein: $STATE_FILE"
    exit 1
  fi
  if [[ -e "$STATE_FILE" ]]; then
    validate_secure_path "$STATE_FILE" "State-Datei" "file"
  fi
}

list_devices() {
  need_cmd pactl
  log "== Sinks/Ausgaben =="
  pactl list short sinks || true
  log ""
  log "== Sources/Eingaben inkl. Monitore =="
  pactl list short sources || true
  log ""
  log "== Nicht-Monitor-Quellen, wahrscheinlich Mikrofone =="
  pactl list short sources | awk '$2 !~ /\.monitor$/ {print}' || true
}

sanitize_default_mic() {
  local src="$1"
  if [[ "$src" == "$VIRT_SOURCE" || "$src" == "$BUS_SINK.monitor" || "$src" == *.monitor ]]; then
    pactl list short sources | awk -v virt="$VIRT_SOURCE" '$2 !~ /\.monitor$/ && $2 != virt {print $2; exit}'
  else
    printf '%s\n' "$src"
  fi
}

resolve_sources() {
  need_cmd pactl
  local default_sink default_source
  default_sink="$(pactl get-default-sink 2>/dev/null || true)"
  default_source="$(pactl get-default-source 2>/dev/null || true)"

  if [[ -z "$SINK" ]]; then
    SINK="$default_sink"
  fi

  if [[ -z "$MONITOR_SOURCE" ]]; then
    if [[ -z "$SINK" ]]; then
      err "Keine Ausgabe gefunden. Bitte mit --sink oder --monitor angeben."
      exit 1
    fi
    MONITOR_SOURCE="${SINK}.monitor"
  fi

  if [[ -z "$MIC_SOURCE" ]]; then
    MIC_SOURCE="$(sanitize_default_mic "$default_source")"
  fi

  if [[ -z "$MIC_SOURCE" ]]; then
    err "Kein echtes Mikrofon gefunden. Nutze 'virt-mic-paw list' und dann --mic SOURCE."
    exit 1
  fi

  if ! pactl list short sources | awk '{print $2}' | grep -Fxq "$MIC_SOURCE"; then
    err "Mikrofon-Source nicht gefunden: $MIC_SOURCE"
    exit 1
  fi

  if ! pactl list short sources | awk '{print $2}' | grep -Fxq "$MONITOR_SOURCE"; then
    err "Monitor-Source nicht gefunden: $MONITOR_SOURCE"
    err "Nutze 'virt-mic-paw list' und prüfe --sink oder --monitor."
    exit 1
  fi
}

unload_modules() {
  ensure_state_dir
  validate_state_file
  if [[ -f "$STATE_FILE" ]]; then
    tac "$STATE_FILE" | while read -r id; do
      if [[ "$id" =~ ^[0-9]+$ ]]; then
        pactl unload-module "$id" 2>/dev/null || true
      elif [[ -n "${id:-}" ]]; then
        warn "Ungültige Modul-ID in State-Datei übersprungen: $id"
      fi
    done
    rm -f "$STATE_FILE"
  fi

  # Aufräumen, falls ein vorheriger Lauf ohne State-Datei übrig blieb.
  pactl list short modules | awk -v app="application.name=$APP" '
    {
      for (i = 1; i <= NF; i++) {
        if ($i == app) {
          print $1
          next
        }
      }
    }
  ' | while read -r id; do
    if [[ -n "${id:-}" ]]; then
      pactl unload-module "$id" 2>/dev/null || true
    fi
  done
}

load_module() {
  local id
  if ! id="$(pactl load-module "$@")"; then
    return 1
  fi
  if ! [[ "$id" =~ ^[0-9]+$ ]]; then
    err "pactl load-module lieferte keine gültige Modul-ID für $1."
    return 1
  fi
  printf '%s\n' "$id" >>"$STATE_FILE"
}

rollback_start_failure() {
  local rc=$?
  trap - ERR
  warn "Start fehlgeschlagen. Räume teilweise geladene Module auf."
  unload_modules
  exit "$rc"
}

start_mix() {
  need_cmd pactl
  ensure_state_dir
  validate_state_file
  : >"$STATE_FILE"
  chmod 0600 "$STATE_FILE"
  validate_secure_path "$STATE_FILE" "State-Datei" "file"

  unload_modules
  : >"$STATE_FILE"
  chmod 0600 "$STATE_FILE"
  resolve_sources
  trap rollback_start_failure ERR

  load_module module-null-sink \
    sink_name="$BUS_SINK" \
    sink_properties="device.description=$BUS_DESC application.name=$APP"

  load_module module-loopback \
    source="$MIC_SOURCE" \
    sink="$BUS_SINK" \
    latency_msec="$LATENCY_MSEC" \
    source_dont_move=true \
    sink_dont_move=true

  load_module module-loopback \
    source="$MONITOR_SOURCE" \
    sink="$BUS_SINK" \
    latency_msec="$LATENCY_MSEC" \
    source_dont_move=true \
    sink_dont_move=true

  load_module module-remap-source \
    master="${BUS_SINK}.monitor" \
    source_name="$VIRT_SOURCE" \
    source_properties="device.description=$SOURCE_DESC application.name=$APP"

  trap - ERR

  if [[ "$SET_DEFAULT_SOURCE" == "1" ]]; then
    pactl set-default-source "$VIRT_SOURCE" || warn "Konnte Default-Source nicht setzen."
  fi

  log "Virt-Mic-Paw läuft."
  log "  Mikrofon:        $MIC_SOURCE"
  log "  Systemaudio:     $MONITOR_SOURCE"
  log "  Virtuelles Mic:  $VIRT_SOURCE ($SOURCE_DESC)"
  log "  Latenz:          ${LATENCY_MSEC} ms"
}

stop_mix() {
  need_cmd pactl
  unload_modules
  log "Virt-Mic-Paw gestoppt."
}

status_mix() {
  need_cmd pactl
  local source_found=0
  log "== Virt-Mic-Paw Module =="
  if pactl list short modules | awk -v app="application.name=$APP" '
    {
      for (i = 1; i <= NF; i++) {
        if ($i == app) {
          print
          found=1
          break
        }
      }
    }
    END {exit found ? 0 : 1}
  '; then
    :
  else
    log "Keine Virt-Mic-Paw-Module gefunden."
  fi
  log ""
  log "== Virtuelle Source =="
  if pactl list short sources | awk -v src="$VIRT_SOURCE" '$2 == src {print; found=1} END {exit found ? 0 : 1}'; then
    source_found=1
  else
    log "Virtuelles Mikrofon nicht aktiv."
  fi
  log ""
  log "== Default Source =="
  pactl get-default-source 2>/dev/null || true
  [[ "$source_found" -eq 1 ]]
}

diag() {
  need_cmd pactl
  log "== pactl info =="
  pactl info || true
  log ""
  log "== Module =="
  pactl list short modules || true
  log ""
  list_devices
  log ""
  status_mix || true
  log ""
  log "== State =="
  log "STATE_FILE=$STATE_FILE"
  if [[ -L "$STATE_DIR" ]]; then
    err "State-Verzeichnis darf kein Symlink sein: $STATE_DIR"
    exit 1
  fi
  if [[ -e "$STATE_FILE" || -L "$STATE_FILE" ]]; then
    validate_state_file
    cat "$STATE_FILE"
  else
    log "Keine State-Datei."
  fi
  log ""
  log "== Config =="
  log "CONFIG_FILE=$CONFIG_FILE"
  if [[ -f "$CONFIG_FILE" ]]; then
    stat -c 'CONFIG_MODE=%a CONFIG_OWNER=%U' "$CONFIG_FILE" 2>/dev/null || true
    log "Config vorhanden; Inhalt wird in diag nicht ausgegeben."
  else
    log "Keine Config-Datei."
  fi
}

parse_start_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mic)
        require_option_value "$1" "${2:-}"
        MIC_SOURCE="$2"; shift 2 ;;
      --sink)
        require_option_value "$1" "${2:-}"
        SINK="$2"; shift 2 ;;
      --monitor)
        require_option_value "$1" "${2:-}"
        MONITOR_SOURCE="$2"; shift 2 ;;
      --latency)
        require_option_value "$1" "${2:-}"
        LATENCY_MSEC="$2"; shift 2 ;;
      --no-default)
        SET_DEFAULT_SOURCE="0"; shift ;;
      -h|--help)
        usage; exit 0 ;;
      *)
        err "Unbekannte Option: $1"; usage; exit 2 ;;
    esac
  done

  if ! [[ "$LATENCY_MSEC" =~ ^[0-9]+$ ]]; then
    err "--latency muss eine Zahl in Millisekunden sein."
    exit 2
  fi

  if [[ "$LATENCY_MSEC" -lt 1 ]]; then
    err "--latency muss mindestens 1 Millisekunde sein."
    exit 2
  fi

  if [[ -n "$SINK" && -n "$MONITOR_SOURCE" ]]; then
    err "--sink und --monitor dürfen nicht gemeinsam gesetzt werden."
    exit 2
  fi

  if [[ "$SET_DEFAULT_SOURCE" != "0" && "$SET_DEFAULT_SOURCE" != "1" ]]; then
    err "VMP_SET_DEFAULT_SOURCE muss 0 oder 1 sein."
    exit 2
  fi
}

require_option_value() {
  local option="$1" value="$2"
  if [[ -z "$value" || "$value" == --* ]]; then
    err "$option benötigt einen Wert."
    exit 2
  fi
}

main() {
  local cmd="${1:-help}"
  shift || true
  load_config

  case "$cmd" in
    start)
      parse_start_args "$@"
      start_mix
      ;;
    stop)
      stop_mix
      ;;
    restart)
      parse_start_args "$@"
      stop_mix >/dev/null || true
      start_mix
      ;;
    status)
      status_mix
      ;;
    list)
      list_devices
      ;;
    config)
      write_default_config
      ;;
    diag|diagnose)
      diag
      ;;
    version|--version)
      show_version
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      err "Unbekannter Befehl: $cmd"
      usage
      exit 2
      ;;
  esac
}

main "$@"
